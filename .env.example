# Hack Club OIDC (auth.hackclub.com)
HACKCLUB_OAUTH_CLIENT_ID=
HACKCLUB_OAUTH_CLIENT_SECRET=
# Must exactly match the registered redirect URI, e.g.
# https://verify.clubs.hackclub.com/auth/callback
HACKCLUB_OAUTH_REDIRECT_URI=

# Random high-entropy secret used to sign the HMAC state param.
# Generate with: openssl rand -hex 32
STATE_SECRET=

# Airtable personal access token (Bearer). Needs read+write on base appUfrUFraxH3D5Ob.
AIRTABLE_API_KEY=

# The Fillout club application form URL leaders are sent back to when done.
CLUB_APPLICATION_FORM_URL=

# Sentry error monitoring + tracing.
# DSN from sentry.io project settings. NEXT_PUBLIC_ is exposed to the browser bundle.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Used by withSentryConfig at build time for source map upload.
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source map upload (build-time only, keep secret). Scopes: project:releases, org:read.
# Stored in .env.sentry-build-plugin (gitignored) rather than committed.
SENTRY_AUTH_TOKEN=
